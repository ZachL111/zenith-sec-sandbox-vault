{
  "repo": "zenith-sec-sandbox-vault",
  "language": "PHP",
  "category": "Security tooling",
  "goal": "Implement a PHP security tooling project for sandbox event replay, using fixture event logs and golden state snapshots.",
  "weights": {
    "signal": 2,
    "slack": 2,
    "confidence": 2,
    "drag": 3
  },
  "thresholds": {
    "ship": 164,
    "watch": 124
  },
  "properties": [
    "raising signal cannot reduce score",
    "raising drag cannot improve score",
    "lane labels must match configured thresholds",
    "golden fixture ids must remain unique"
  ],
  "fixture_files": [
    "fixtures/golden/scoreboard.csv",
    "fixtures/golden/lane-matrix.csv",
    "fixtures/fuzz/mutations.csv",
    "fixtures/fuzz/boundary-cases.jsonl"
  ]
}
